{
  "name": "DocuTools Pro - Dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  
  "customizations": {
    "codespaces": {
      "openFiles": [
        "app.py",
        "requirements.txt"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml",
        "GitHub.copilot"
      ]
    }
  },

  "updateContentCommand": "sudo apt-get update && sudo apt-get install -y $(cat packages.txt) && pip3 install --upgrade pip && pip3 install -r requirements.txt",
  
  "postAttachCommand": {
    "server": "streamlit run app.py --server.port 8501 --server.enableCORS false --server.enableXsrfProtection false"
  },

  "portsAttributes": {
    "8501": {
      "label": "DocuTools App",
      "onAutoForward": "openPreview"
    }
  },
  
  "forwardPorts": [
    8501
  ]
}
